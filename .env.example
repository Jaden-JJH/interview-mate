# Anthropic Claude API
# https://console.anthropic.com/settings/keys


# Public site URL (used for absolute URLs, OG, etc.)
# Local: http://localhost:3000
# Preview: auto-set by Vercel
# Prod: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Clerk Auth (https://dashboard.clerk.com)
# All three should be set for Production, Preview, AND Development on Vercel
# so `vercel env pull` keeps them in sync.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Set to the "Signing Secret" shown when registering the webhook endpoint
# (Clerk Dashboard → Webhooks → /api/webhooks/clerk endpoint)
CLERK_WEBHOOK_SIGNING_SECRET=

# Neon Postgres connection (provisioned via Vercel Marketplace → Storage → Neon)
# Vercel Marketplace prefixes injected vars with the project name; pull with
# `vercel env pull`. The app reads either name (DATABASE_URL preferred).
DATABASE_URL=
# interview_mate_DATABASE_URL=  # auto-injected by the Neon integration on Vercel

