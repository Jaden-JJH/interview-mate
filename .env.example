# Anthropic Claude API
# https://console.anthropic.com/settings/keys


# PostHog (error monitoring + analytics)
# https://us.posthog.com/settings/project → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side only (event capture from API routes) — same key, no NEXT_PUBLIC_ prefix
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# Search engine verification (get codes from each console)
# Google Search Console → Settings → Ownership verification → HTML tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Naver Search Advisor → 사이트 등록 → HTML 태그 인증
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
# Bing Webmaster Tools → Add site → XML file or Meta tag
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Public site URL (used for absolute URLs, OG, sitemap, robots, JSON-LD)
# Local: http://localhost:3000
# Preview: auto-set by Vercel (or set to preview URL)
# Prod: https://interview-mate.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Clerk Auth (https://dashboard.clerk.com)
# All three should be set for Production, Preview, AND Development on Vercel
# so `vercel env pull` keeps them in sync.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Set to the "Signing Secret" shown when registering the webhook endpoint
# (Clerk Dashboard → Webhooks → /api/webhooks/clerk endpoint)
CLERK_WEBHOOK_SIGNING_SECRET=

# Neon Postgres connection (provisioned via Vercel Marketplace → Storage → Neon)
# Vercel Marketplace prefixes injected vars with the project name; pull with
# `vercel env pull`. The app reads either name (DATABASE_URL preferred).
DATABASE_URL=
# interview_mate_DATABASE_URL=  # auto-injected by the Neon integration on Vercel

